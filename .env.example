PORT=8080
ENV=development

# Optional — strongly recommended to avoid GitHub's 60 req/hr unauthenticated limit.
# With a token the limit is 5,000 req/hr (REST) / 5,000 pts/hr (GraphQL).
GITHUB_TOKEN=ghp_your_token_here

# Seconds to cache GitHub API responses in memory (default: 300 = 5 minutes).
CACHE_TTL=300
